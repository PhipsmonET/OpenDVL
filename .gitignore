# ==============================================================================
# OpenDVL - Git Ignore Configuration
# Professional template for Embedded (STM32H7), Electronics (KiCad 10), and CAD
# ==============================================================================

# ------------------------------------------------------------------------------
# System & IDE files
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.log
*.tmp
*~
*.swp
*.bak
*.back

# ------------------------------------------------------------------------------
# STM32 / Firmware / Build artifacts
# ------------------------------------------------------------------------------
# GCC / CMake / Make build directories
[Bb]uild/
[Dd]ebug/
[Rr]elease/
bin/
obj/

# STM32CubeIDE / Eclipse files
.settings/
.mxproject
*.launch
.project
.cproject

# VS Code local workspace
.vscode/ipch/
.vscode/browse.vc.db
.vscode/cmake-variants.json

# Keil / UVision
*.uvopt*
*.uvproj*
Listings/
Objects/

# IAR
*.dep
*.ewd
*.ewp
*.eww

# ------------------------------------------------------------------------------
# KiCad 10 / Electronics
# ------------------------------------------------------------------------------
# KiCad backup & temporary files
*-bak
*-back
*.kicad_pcb-bak
*.kicad_sch-bak
*.sch-bak
_autosave-*
*.orig
*~

# KiCad ERC/DRC report files
*.rpt
*.erc
*.drc

# KiCad dynamic local cache
fp-info-cache
*.pyc

# Local symbols / footprints / 3D libraries downloaded dynamically or generated
# Note: Keep manually added project-specific libraries tracked!
# electronics/libs/3d/ (keep unless huge, then ignore)
# electronics/libs/footprints/ (keep)
# electronics/libs/symbols/ (keep)

# KiCad fabrication output (if generated inside a temporary folder)
# electronics/fab/ (uncomment if you want to exclude local fab outputs)

# ------------------------------------------------------------------------------
# Fusion 360 / Mechanical / CAD exports
# ------------------------------------------------------------------------------
# Local lock files or temp files generated by CAD viewers / converters
.~*
*.$$$
*.log
*.err
*.bak
*.dwl
*.dwl2
*.gcode
